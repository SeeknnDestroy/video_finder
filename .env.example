APP_DB_PATH=./data/video_finder.db
YOUTUBE_API_KEY=
GROQ_API_KEY=
LOG_LEVEL=INFO

GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo
# Legacy alias still accepted: TRANSCRIBE_MODEL_SIZE=turbo|large
# Optional advanced overrides. By default, the app retries common logged-in browsers
# automatically when YouTube requires sign-in for a video.
YT_DLP_COOKIES_FROM_BROWSER=
YT_DLP_COOKIES_FILE=
TRANSCRIBE_LANGUAGE=
TRANSCRIBE_WORKER_CONCURRENCY=1
TRANSCRIBE_JOB_MAX_CANDIDATES=200
TRANSCRIBE_WORKER_POLL_SECONDS=2
TRANSCRIBE_WORKER_ENABLED=true
